            validation_result = validate_chapter_completeness(chunk_result, current_start, current_end)
            if validation_result['is_valid']:
                logging.info(f"✅ Retry {retry_count} successful: Chapters [{current_start}..{current_end}] passed validation")
                break
            else:
                logging.error(f"❌ Retry {retry_count} failed: {validation_result['critical_errors']}")

        # 如果重试3次后仍然失败，尝试修复生成的内容
        if not validation_result['is_valid']:
            logging.error(f"🚨 Failed to generate clean chapters [{current_start}..{current_end}] after {max_retries} retries.")
            logging.error(f"Validation errors: {validation_result['critical_errors']}")

            # 尝试修复生成的内容：移除省略号部分
            try:
                fixed_result = attempt_to_fix_ellipsis_content(chunk_result, current_start, current_end)
                if fixed_result and fixed_result.strip():
                    logging.info(f"✅ Successfully cleaned chapters [{current_start}..{current_end}] - removing省略号")
                    if final_blueprint.strip():
                        final_blueprint += "\n\n" + fixed_result.strip()
                    else:
                        final_blueprint = fixed_result.strip()
                    logging.info(f"📝 Added repaired chapters [{current_start}..{current_end}] to final blueprint")
                else:
                    logging.error(f"❌ Could not fix chapters [{current_start}..{current_end}], skipping")
                    logging.error(f"Missing chapters: {list(range(current_start, current_end + 1))}")
            except Exception as e:
                logging.error(f"❌ Error during content fixing: {e}")
                logging.error(f"Missing chapters: {list(range(current_start, current_end + 1))}")

            current_start = current_end + 1
            continue

        logging.info(f"Expected {current_end - current_start + 1} chapters [{current_start}..{current_end}], validation result: {validation_result['warnings']}")

