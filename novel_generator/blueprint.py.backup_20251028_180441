def attempt_to_fix_ellipsis_content(content: str, expected_start: int, expected_end: int) -> str:
    """
    尝试修复包含省略号的内容，移除省略号部分并保留有效的章节内容
    """
    try:
        lines = content.split('\n')
        fixed_lines = []
        current_chapter = expected_start

        # 模式匹配章节标题
        chapter_pattern = r'^第\s*(\d+)\s*章'
        ellipsis_indicators = [
            '...', '…', '省略', '跳过', '从略', '详见', '同上', '类似',
            '后续章节类似', '后续类似', '等等', 'etc', '以此类推',
            '篇幅限制', '此处省略', '由于篇幅', '字数限制',
            '受限于篇幅', '为了节省篇幅', '由于内容过长'
        ]

        for line in lines:
            line = line.strip()
            if not line:
                continue

            # 检查是否是章节标题
            chapter_match = re.match(chapter_pattern, line)
            if chapter_match:
                chapter_num = int(chapter_match.group(1))
                if expected_start <= chapter_num <= expected_end:
                    fixed_lines.append(line)
                    current_chapter = chapter_num
                    continue

            # 检查是否包含省略号指示
            is_ellipsis_line = any(indicator in line for indicator in ellipsis_indicators)

            # 如果包含省略号但不是章节标题，可能是有用的描述性内容
            if not is_ellipsis_line and not any(keyword in line for keyword in ['省略', '跳过', '从略']):
                # 检查是否是有意义的描述内容（长度超过20个字符）
                if len(line) > 20:
                    fixed_lines.append(line)
            elif is_ellipsis_line:
                logging.warning(f"Removing ellipsis line: {line[:50]}...")
                continue

        # 重新组合内容
        fixed_content = '\n'.join(fixed_lines)

        # 验证修复后的内容是否包含有效的章节
        fixed_chapters = re.findall(chapter_pattern, fixed_content)
        if len(fixed_chapters) > 0:
            logging.info(f"Content fixing: {len(fixed_chapters)} valid chapters found out of expected {expected_end - expected_start + 1}")
            return fixed_content
        else:
            logging.warning("Content fixing: No valid chapters found after cleaning")
            return ""

    except Exception as e:
        logging.error(f"Error in content fixing: {e}")
        return ""


def validate_chapter_completeness(result_text: str, expected_start: int, expected_end: int) -> dict:
    """
    验证章节生成的完整性 - Ultra强化版本
    返回包含验证结果的字典
    """
    result = {
        "is_valid": True,
        "warnings": [],
        "missing_chapters": [],
        "has_ellipsis": False,
        "has_skipping_language": False,
        "critical_errors": []
    }

    # 🔥 严格检查所有类型的省略号和跳过表述
    ellipsis_patterns = [
        r"\.\.\.", "…", "后续章节类似", "后续类似", "等等", "etc", "以此类推",
        "省略", "跳过", "从略", "详见", "同上", "类似", "其余类似",
        "后续X章", "后续.*章", "第.*章至第.*章", "从第.*章开始",
        "将按照此格式", "按照此模式", "生成.*章",
        # 🚨 新增的篇幅限制相关表述
        "篇幅限制", "此处省略", "由于篇幅", "字数限制", "篇幅所限",
        "详细内容.*省略", "省略.*详细内容", "省略.*第.*章", "第.*章.*省略",
        "节奏规划.*生成", "严格按照.*规划", "由于.*限制.*省略"
    ]

    for pattern in ellipsis_patterns:
        if re.search(pattern, result_text):
            result["has_ellipsis"] = True
            result["is_valid"] = False
            result["critical_errors"].append(f"🚨 检测到省略号或跳过表述: '{pattern}'")

    # 🔥 检查偷懒模式表述
    lazy_patterns = [
        r"后续.*章.*格式", r"第\d+章.*后续.*格式", r"以此.*推",
        r"生成.*至.*章", r"第.*章到第.*章", r"共.*章"
    ]

    for pattern in lazy_patterns:
        if re.search(pattern, result_text):
            result["has_skipping_language"] = True
            result["is_valid"] = False
            result["critical_errors"].append(f"🚨 检测到偷懒表述: '{pattern}'")

    # 🔥 精确检查章节数量和顺序
    chapter_pattern = r"第\s*(\d+)\s*章"
    generated_chapters = re.findall(chapter_pattern, result_text)
    generated_numbers = [int(x) for x in generated_chapters if x.isdigit()]

    expected_count = expected_end - expected_start + 1

    # 检查是否缺少章节
    if len(generated_numbers) < expected_count:
        missing_chapters = set(range(expected_start, expected_end + 1)) - set(generated_numbers)
        result["missing_chapters"] = sorted(missing_chapters)
        result["warnings"].append(f"❌ 缺少{len(missing_chapters)}章: {result['missing_chapters']}")
        result["is_valid"] = False
        result["critical_errors"].append(f"严重错误：期望{expected_count}章，实际只生成{len(generated_numbers)}章")

    # 检查是否有超出范围的章节
    out_of_range = [num for num in generated_numbers if num < expected_start or num > expected_end]
    if out_of_range:
        result["warnings"].append(f"❌ 超出范围的章节: {out_of_range}")
        result["is_valid"] = False
        result["critical_errors"].append(f"严重错误：生成超出范围的章节 {out_of_range}")

    # 🔥 检查章节是否连续
    if generated_numbers:
        generated_numbers_sorted = sorted(generated_numbers)
        gaps = []
        for i in range(1, len(generated_numbers_sorted)):
            if generated_numbers_sorted[i] - generated_numbers_sorted[i-1] > 1:
                gaps.extend(range(generated_numbers_sorted[i-1]+1, generated_numbers_sorted[i]))

        if gaps:
            result["warnings"].append(f"❌ 章节不连续，存在跳跃: {gaps}")
            result["is_valid"] = False
            result["critical_errors"].append(f"严重错误：章节不连续，跳跃了 {gaps}")

    # 🔥 检查内容长度（仅在极短内容时警告，避免误判）
    min_chars_per_chapter = 20  # 进一步降低阈值到每章20字
    if len(result_text.strip()) < expected_count * min_chars_per_chapter:
        result["warnings"].append(f"⚠️ 生成内容较短，建议检查是否存在省略（期望至少{expected_count * min_chars_per_chapter}字符）")
        # 只有在内容极其简短时才标记为无效
        if len(result_text.strip()) < expected_count * 5:  # 每章少于5字才认为无效
            result["is_valid"] = False
            result["critical_errors"].append("严重错误：生成内容过短，存在大量省略")

    return result

def compute_chunk_size(number_of_chapters: int, max_tokens: int) -> int:
    """
    基于"每章约100 tokens"的粗略估算，
    再结合当前max_tokens，计算分块大小：
      chunk_size = (floor(max_tokens/100/10)*10) - 10
    并确保 chunk_size 不会小于1或大于实际章节数。
    """
    # 确保章节数有合理的默认值
    if number_of_chapters <= 0:
        number_of_chapters = 50  # 默认50章
        logging.warning(f"Invalid number_of_chapters ({number_of_chapters}), using default value 50")

    tokens_per_chapter = 200.0
    ratio = max_tokens / tokens_per_chapter
    ratio_rounded_to_10 = int(ratio // 10) * 10
    chunk_size = ratio_rounded_to_10 - 10
    if chunk_size < 1:
        chunk_size = 1
    if chunk_size > number_of_chapters:
        chunk_size = number_of_chapters
    return chunk_size

def limit_chapter_blueprint(blueprint_text: str, limit_chapters: int = 100) -> str:
    """
    从已有章节目录中只取最近的 limit_chapters 章，以避免 prompt 超长。
    """
    pattern = r"(第\s*\d+\s*章.*?)(?=第\s*\d+\s*章|$)"
    chapters = re.findall(pattern, blueprint_text, flags=re.DOTALL)
    if not chapters:
        return blueprint_text
    if len(chapters) <= limit_chapters:
        return blueprint_text
    selected = chapters[-limit_chapters:]
    return "\n\n".join(selected).strip()

def Chapter_blueprint_generate(
    interface_format: str,
    api_key: str,
    base_url: str,
    llm_model: str,
    filepath: str,
    number_of_chapters: int,
    user_guidance: str = "",  # 新增参数
    temperature: float = 0.7,
    max_tokens: int = 4096,
    timeout: int = 600
) -> None:
    """
    若 Novel_directory.txt 已存在且内容非空，则表示可能是之前的部分生成结果；
      解析其中已有的章节数，从下一个章节继续分块生成；
      对于已有章节目录，传入时仅保留最近100章目录，避免prompt过长。
    否则：
      - 若章节数 <= chunk_size，直接一次性生成
      - 若章节数 > chunk_size，进行分块生成
    生成完成后输出至 Novel_directory.txt。
    """
    arch_file = os.path.join(filepath, "Novel_architecture.txt")
    if not os.path.exists(arch_file):
        logging.warning("Novel_architecture.txt not found. Please generate architecture first.")
        return

    architecture_text = read_file(arch_file).strip()
    if not architecture_text:
        logging.warning("Novel_architecture.txt is empty.")
        return

    llm_adapter = create_llm_adapter(
        interface_format=interface_format,
        base_url=base_url,
        model_name=llm_model,
        api_key=api_key,
        temperature=temperature,
        max_tokens=max_tokens,
        timeout=timeout
    )

    filename_dir = os.path.join(filepath, "Novel_directory.txt")
    if not os.path.exists(filename_dir):
        open(filename_dir, "w", encoding="utf-8").close()

    existing_blueprint = read_file(filename_dir).strip()
    chunk_size = compute_chunk_size(number_of_chapters, max_tokens)
    logging.info(f"Number of chapters = {number_of_chapters}, computed chunk_size = {chunk_size}.")

    if existing_blueprint:
        logging.info("Detected existing blueprint content. Will resume chunked generation from that point.")
        pattern = r"第\s*(\d+)\s*章"
        existing_chapter_numbers = re.findall(pattern, existing_blueprint)
        existing_chapter_numbers = [int(x) for x in existing_chapter_numbers if x.isdigit()]
        max_existing_chap = max(existing_chapter_numbers) if existing_chapter_numbers else 0
        logging.info(f"Existing blueprint indicates up to chapter {max_existing_chap} has been generated.")
        final_blueprint = existing_blueprint
        current_start = max_existing_chap + 1
        while current_start <= number_of_chapters:
            current_end = min(current_start + chunk_size - 1, number_of_chapters)
            limited_blueprint = limit_chapter_blueprint(final_blueprint, 100)
            chunk_prompt = chunked_chapter_blueprint_prompt.format(
                novel_architecture=architecture_text,
                chapter_list=limited_blueprint,
                number_of_chapters=number_of_chapters,
                n=current_start,
                m=current_end,
                user_guidance=user_guidance  # 新增参数
            )
            logging.info(f"Generating chapters [{current_start}..{current_end}] in a chunk...")
            chunk_result = invoke_with_cleaning(llm_adapter, chunk_prompt)
            if not chunk_result.strip():
                logging.warning(f"Chunk generation for chapters [{current_start}..{current_end}] is empty.")
                clear_file_content(filename_dir)
                save_string_to_txt(final_blueprint.strip(), filename_dir)
                return

            # 🔥 验证生成的章节数量和完整性
            validation_result = validate_chapter_completeness(chunk_result, current_start, current_end)

            # 记录所有严重错误
            for error in validation_result['critical_errors']:
                logging.error(f"🚨 Critical validation error: {error}")

            # 🔥 如果验证失败，强制重新生成（最多重试3次）
            max_retries = 3
            retry_count = 0
            while not validation_result['is_valid'] and retry_count < max_retries:
                retry_count += 1
                logging.error(f"🔄 Chapter generation failed validation (attempt {retry_count}/{max_retries}). Regenerating chapters [{current_start}..{current_end}]...")

                # 构建更严格的重新生成提示
                retry_prompt = chunk_prompt + f"""

🚨【严重错误 - 重新生成警告】🚨
上一次生成失败，检测到以下问题：
{chr(10).join(validation_result['critical_errors'])}

🔥【特别警告 - 禁止使用篇幅限制借口】🔥
绝对禁止以下表述：
- "由于篇幅限制"
- "此处省略"
- "字数限制"
- "篇幅所限"
- "详细内容省略"
- "节奏规划生成"

📋【重新生成严格要求】
请重新生成第{current_start}章到第{current_end}章，确保：
1. 生成全部{current_end - current_start + 1}章，一章都不能省略
2. 不要使用任何形式的省略号，包括以"篇幅限制"为借口的省略
3. 每章都要有完整的结构和内容，不能以任何理由跳过
4. 无论内容多长，都必须完整生成所有章节

这是第{retry_count}次重试，如果再次使用篇幅限制等借口，将继续重试直到成功为止！
"""

                chunk_result = invoke_with_cleaning(llm_adapter, retry_prompt)
                if not chunk_result.strip():
                    logging.error(f"Retry {retry_count}: Empty result for chapters [{current_start}..{current_end}]")
                    continue

                # 重新验证
                validation_result = validate_chapter_completeness(chunk_result, current_start, current_end)
                if validation_result['is_valid']:
                    logging.info(f"✅ Retry {retry_count} successful: Chapters [{current_start}..{current_end}] passed validation")
                    break
                else:
                    logging.error(f"❌ Retry {retry_count} failed: {validation_result['critical_errors']}")

            # 如果重试3次后仍然失败，记录严重错误并跳过这个块
            if not validation_result['is_valid']:
                logging.error(f"🚨 FATAL: Failed to generate chapters [{current_start}..{current_end}] after {max_retries} retries. Skipping this chunk.")
                logging.error(f"Missing chapters: {list(range(current_start, current_end + 1))}")
                # 继续处理下一块，但会在最终验证中被标记
                continue

            logging.info(f"Expected {current_end - current_start + 1} chapters [{current_start}..{current_end}], validation result: {validation_result['warnings']}")
            final_blueprint += "\n\n" + chunk_result.strip()
            clear_file_content(filename_dir)
            save_string_to_txt(final_blueprint.strip(), filename_dir)
            current_start = current_end + 1

        logging.info("All chapters blueprint have been generated (resumed chunked).")
        return

    if chunk_size >= number_of_chapters:
        prompt = chapter_blueprint_prompt.format(
            novel_architecture=architecture_text,
            number_of_chapters=number_of_chapters,
            user_guidance=user_guidance  # 新增参数
        )
        blueprint_text = invoke_with_cleaning(llm_adapter, prompt)
        if not blueprint_text.strip():
            logging.warning("Chapter blueprint generation result is empty.")
            return

        # 🔥 验证生成的章节数量和完整性
        validation_result = validate_chapter_completeness(blueprint_text, 1, number_of_chapters)

        # 记录所有严重错误
        for error in validation_result['critical_errors']:
            logging.error(f"🚨 Critical validation error: {error}")

        # 🔥 如果验证失败，强制重新生成（最多重试3次）
        max_retries = 3
        retry_count = 0
        while not validation_result['is_valid'] and retry_count < max_retries:
            retry_count += 1
            logging.error(f"🔄 Full generation failed validation (attempt {retry_count}/{max_retries}). Regenerating all {number_of_chapters} chapters...")

            # 构建更严格的重新生成提示
            retry_prompt = prompt + f"""

🚨【严重错误 - 重新生成警告】🚨
上一次生成失败，检测到以下问题：
{chr(10).join(validation_result['critical_errors'])}

🔥【特别警告 - 禁止使用篇幅限制借口】🔥
绝对禁止以下表述：
- "由于篇幅限制"
- "此处省略"
- "字数限制"
- "篇幅所限"
- "详细内容省略"
- "节奏规划生成"

📋【重新生成严格要求】
请重新生成全部{number_of_chapters}章，确保：
1. 生成全部{number_of_chapters}章，从第1章到第{number_of_chapters}章，一章都不能省略
2. 不要使用任何形式的省略号，包括以"篇幅限制"为借口的省略
3. 每章都要有完整的结构和内容，不能以任何理由跳过
4. 无论内容多长，都必须完整生成所有章节

这是第{retry_count}次重试，如果再次使用篇幅限制等借口，将继续重试直到成功为止！
"""

            blueprint_text = invoke_with_cleaning(llm_adapter, retry_prompt)
            if not blueprint_text.strip():
                logging.error(f"Retry {retry_count}: Empty result for full generation")
                continue

            # 重新验证
            validation_result = validate_chapter_completeness(blueprint_text, 1, number_of_chapters)
            if validation_result['is_valid']:
                logging.info(f"✅ Retry {retry_count} successful: Full generation passed validation")
                break
            else:
                logging.error(f"❌ Retry {retry_count} failed: {validation_result['critical_errors']}")

        # 如果重试3次后仍然失败，尝试修复生成的内容
        if not validation_result['is_valid']:
            logging.error(f"🚨 Failed to generate clean directory after {max_retries} retries.")
            logging.error(f"Validation errors: {validation_result['critical_errors']}")

            # 尝试修复生成的内容：移除省略号部分
            try:
                fixed_content = attempt_to_fix_ellipsis_content(blueprint_text, 1, number_of_chapters)
                if fixed_content and fixed_content.strip():
                    logging.info(f"✅ Successfully cleaned directory - removing省略号")
                    clear_file_content(filename_dir)
                    save_string_to_txt(fixed_content, filename_dir)
                    logging.info("Saved cleaned directory with available chapters.")
                else:
                    logging.error("❌ Could not fix directory content, saving partial result")
                    clear_file_content(filename_dir)
                    save_string_to_txt(blueprint_text, filename_dir)
                    logging.error("Saved partial directory. Please regenerate manually.")
            except Exception as e:
                logging.error(f"❌ Error during directory cleaning: {e}")
                logging.error("Saving original result. Please regenerate manually.")
                clear_file_content(filename_dir)
                save_string_to_txt(blueprint_text, filename_dir)
            return

        logging.info(f"Expected {number_of_chapters} chapters in total, validation result: {validation_result['warnings']}")

        # 记录所有警告
        for warning in validation_result['warnings']:
            logging.warning(f"Chapter generation warning: {warning}")

        clear_file_content(filename_dir)
        save_string_to_txt(blueprint_text, filename_dir)
        logging.info("Novel_directory.txt (chapter blueprint) has been generated successfully (single-shot).")
        return

    logging.info("Will generate chapter blueprint in chunked mode from scratch.")
    final_blueprint = ""
    current_start = 1
    while current_start <= number_of_chapters:
        current_end = min(current_start + chunk_size - 1, number_of_chapters)
        limited_blueprint = limit_chapter_blueprint(final_blueprint, 100)
        chunk_prompt = chunked_chapter_blueprint_prompt.format(
            novel_architecture=architecture_text,
            chapter_list=limited_blueprint,
            number_of_chapters=number_of_chapters,
            n=current_start,
            m=current_end,
            user_guidance=user_guidance  # 新增参数
        )
        logging.info(f"Generating chapters [{current_start}..{current_end}] in a chunk...")
        chunk_result = invoke_with_cleaning(llm_adapter, chunk_prompt)
        if not chunk_result.strip():
            logging.warning(f"Chunk generation for chapters [{current_start}..{current_end}] is empty.")
            clear_file_content(filename_dir)
            save_string_to_txt(final_blueprint.strip(), filename_dir)
            return

        # 🔥 验证生成的章节数量和完整性
        validation_result = validate_chapter_completeness(chunk_result, current_start, current_end)

        # 记录所有严重错误
        for error in validation_result['critical_errors']:
            logging.error(f"🚨 Critical validation error: {error}")

        # 🔥 如果验证失败，强制重新生成（最多重试3次）
        max_retries = 3
        retry_count = 0
        while not validation_result['is_valid'] and retry_count < max_retries:
            retry_count += 1
            logging.error(f"🔄 Chunk generation failed validation (attempt {retry_count}/{max_retries}). Regenerating chapters [{current_start}..{current_end}]...")

            # 构建更严格的重新生成提示
            retry_prompt = chunk_prompt + f"""

🚨【严重错误 - 重新生成警告】🚨
上一次生成失败，检测到以下问题：
{chr(10).join(validation_result['critical_errors'])}

🔥【特别警告 - 禁止使用篇幅限制借口】🔥
绝对禁止以下表述：
- "由于篇幅限制"
- "此处省略"
- "字数限制"
- "篇幅所限"
- "详细内容省略"
