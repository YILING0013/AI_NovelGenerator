class AutoFixer:
    """自动修复器"""

    def __init__(self, knowledge_base: DynamicWorldKnowledgeBase):
        self.knowledge_base = knowledge_base

    def fix_issue(self, issue: ConsistencyIssue, content: str) -> Dict[str, Any]:
        """修复一致性问题"""
        result = {
            'success': False,
            'fixed_content': content,
            'changes': []
        }

        try:
            if issue.type == "unknown_character":
                # 删除未知角色提及
                fixed_content = content.replace(issue.conflicting_elements[0], "")
                result['success'] = True
                result['fixed_content'] = fixed_content
                result['changes'].append(f"删除未知角色提及：{issue.conflicting_elements[0]}")

            elif issue.type == "unknown_setting":
                # 删除未知设定提及
                fixed_content = content.replace(issue.conflicting_elements[0], "")
                result['success'] = True
                result['fixed_content'] = fixed_content
                result['changes'].append(f"删除未知设定提及：{issue.conflicting_elements[0]}")

            elif issue.type == "plot_timeline_conflict":
                # 调整事件位置
                # 这里可以实现更复杂的时间线调整逻辑
                result['success'] = True
                result['changes'].append("调整情节时间线")

        except Exception as e:
            logging.error(f"自动修复失败: {e}")

        return result


# 工厂函数
def create_dynamic_world_knowledge_base(project_path: str, config: Optional[Dict[str, Any]] = None) -> DynamicWorldKnowledgeBase:
    """创建动态世界知识库实例"""
    return DynamicWorldKnowledgeBase(project_path, config)

# 示例使用
async def main():
    """示例使用"""
    # 创建动态世界知识库
    knowledge_base = create_dynamic_world_knowledge_base("./test_project")

    # 添加角色
    protagonist = CharacterProfile(
        id="char_001",
        name="叶辰",
        aliases=["叶大师", "辰哥"],
        appearance="身材修长，面容俊朗，眼神锐利",
        personality="坚毅果断，重情重义",
        cultivation_level="炼气期九层",
        skills=["基础剑法", "炼气术"],
        relationships={"师父": "玄机子", "朋友": "林雪儿"}
    )

    knowledge_base.add_character(protagonist)

    # 添加世界设定
    cultivation_system = WorldSetting(
        id="setting_001",
        name="修真等级体系",
        category="cultivation",
        description="修真者的修炼等级划分",
        rules=["炼气期", "筑基期", "金丹期", "元婴期", "化神期"],
        consistency_level=ConsistencyLevel.CRITICAL
    )

    knowledge_base.add_world_setting(cultivation_system)

    # 添加情节事件
    tournament_event = PlotEvent(
        id="event_001",
        title="宗门大比初赛",
        chapter_id=5,
        timeline_position=100,
        location="演武场",
        involved_characters=["叶辰", "李威"],
        event_type="competition",
        description="叶辰参加宗门大比初赛",
        importance=8
    )

    knowledge_base.add_plot_event(tournament_event)

    # 测试检索功能
    query = "叶辰的修炼等级"
    context = knowledge_base.get_relevant_context(query)

    print("🔍 检索结果:")
    for item in context:
        print(f"  {item['type']}: {item.get('name', item.get('title', ''))} (相关度: {item['relevance']:.2f})")
        print(f"    {item['content'][:100]}...")

    # 获取统计信息
    stats = knowledge_base.get_statistics()
    print(f"\n📊 知识库统计:")
    print(f"  角色: {stats['characters']}")
    print(f"  设定: {stats['settings']}")
    print(f"  情节: {stats['plot_events']}")

if __name__ == "__main__":
    asyncio.run(main())