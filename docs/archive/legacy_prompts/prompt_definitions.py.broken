# ────────────────── 修为进度管理器 ──────────────────
# 通用玄幻修为体系（章节范围 -> 境界约束）
# 通用玄幻修为体系（章节范围 -> 境界约束）
# 9大境界：炼气、筑基、金丹、元婴、化神、炼虚、合体、大乘、渡劫
CULTIVATION_PROGRESS_MAP = {
    (1, 10): ("炼气初期", "炼气圆满"),      # 约3万字：新手村，五气朝元基础
    (11, 30): ("筑基初期", "筑基圆满"),     # 约10万字：铸造完美道基
    (31, 60): ("金丹初期", "金丹圆满"),     # 约20万字：龙虎交汇，混元一气
    (61, 100): ("元婴初期", "元婴圆满"),    # 约40万字：显化法相，第二条命
    (101, 150): ("化神初期", "化神圆满"),   # 约60万字：神游太虚，借天地势
    (151, 220): ("炼虚初期", "炼虚圆满"),   # 约80万字：体内洞天，自成世界
    (221, 300): ("合体初期", "合体圆满"),   # 约120万字：万流归宗，肉身不朽
    (301, 360): ("大乘初期", "大乘圆满"),   # 约160万字：言出法随，陆地神仙
    (361, 400): ("渡劫初期", "飞升"),       # 约200万字：逆天改命，终极大考
}

def get_cultivation_constraint(chapter_num: int) -> dict:
    """根据章节号返回修为约束"""
    for (start, end), (current, max_realm) in CULTIVATION_PROGRESS_MAP.items():
        if start <= chapter_num <= end:
            return {
                "current_realm": current,
                "max_realm": max_realm,
                "constraint_text": f"【修为锁定】主角当前境界应在【{current}】附近，本章最多可突破至【{max_realm}】，禁止跳级！"
            }
    # 超出范围则不限制
    return {"current_realm": "自由", "max_realm": "自由", "constraint_text": ""}

